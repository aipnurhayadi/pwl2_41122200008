# Copy this file to .env and fill in your values
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/pwl2_db

# CORS: comma-separated list of allowed origins (leave empty to disable CORS)
# Example: http://localhost:5173,http://localhost:3000
ALLOW_ORIGINS=http://localhost:5173

# JWT secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
